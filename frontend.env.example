NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional fallback: the shared bot can now be configured from the UI (Profile >
# Telegram Bot Kurulumu), which stores the token/secret in app_telegram_settings.
# These env vars are only used when no UI config exists.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here
# Comma-separated emails allowed to configure the shared bot from the UI.
TELEGRAM_ADMIN_EMAILS=you@example.com
NEXT_PUBLIC_APP_URL=https://taskflow.arslanyusuf.com
NEXT_PUBLIC_API_BASE_PATH=/api
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3021
