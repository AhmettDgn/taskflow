{
  "name": "taskflow-workspace",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:localhost": "node ./scripts/dev-localhost.mjs",
    "build": "pnpm --filter frontend build && pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "test:unit": "pnpm --filter frontend test:unit",
    "test:integration": "pnpm --filter frontend test:integration",
    "test:e2e": "pnpm --filter frontend test:e2e",
    "test:smoke": "pnpm --filter frontend test:smoke",
    "test:functional": "pnpm --filter frontend test:functional",
    "test:regression": "pnpm --filter frontend test:regression",
    "test:predeploy": "pnpm --filter frontend test:predeploy",
    "start:frontend": "pnpm --filter frontend start",
    "start:backend": "pnpm --filter backend start"
  }
}
